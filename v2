<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Brainfish — Homepage V2 Mockup</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --navy: #0d1b2e;
      --navy-mid: #112240;
      --navy-light: #1a2f50;
      --blue: #2563eb;
      --blue-light: #3b82f6;
      --cyan: #06b6d4;
      --cyan-pale: #cffafe;
      --white: #ffffff;
      --gray-50: #f8fafc;
      --gray-100: #f1f5f9;
      --gray-300: #cbd5e1;
      --gray-400: #94a3b8;
      --gray-500: #64748b;
      --gray-600: #475569;
      --green: #10b981;
      --orange: #f97316;
      --red-pale: #fee2e2;
      --red: #ef4444;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--navy);
      color: var(--white);
      line-height: 1.6;
      overflow-x: hidden;
    }

    /* ─── NAV ─── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 48px;
      height: 68px;
      background: rgba(13, 27, 46, 0.92);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    .nav-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      font-weight: 700;
      font-size: 18px;
      letter-spacing: -0.3px;
    }

    .nav-logo-icon {
      width: 32px; height: 32px;
      background: linear-gradient(135deg, var(--blue), var(--cyan));
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 16px;
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 32px;
      list-style: none;
    }

    .nav-links a {
      color: var(--gray-300);
      text-decoration: none;
      font-size: 14px;
      font-weight: 500;
      transition: color 0.2s;
    }

    .nav-links a:hover { color: var(--white); }

    .nav-actions {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .btn-ghost {
      background: transparent;
      border: 1px solid rgba(255,255,255,0.15);
      color: var(--white);
      padding: 8px 18px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.2s;
      font-family: 'Inter', sans-serif;
    }

    .btn-ghost:hover { border-color: rgba(255,255,255,0.4); }

    .btn-primary {
      background: var(--blue);
      border: none;
      color: var(--white);
      padding: 9px 20px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
      font-family: 'Inter', sans-serif;
    }

    .btn-primary:hover { background: var(--blue-light); }

    /* ─── HERO ─── */
    .hero {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 140px 24px 80px;
      position: relative;
      overflow: hidden;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 80% 50% at 50% 0%, rgba(37, 99, 235, 0.18) 0%, transparent 70%),
        radial-gradient(ellipse 50% 40% at 80% 60%, rgba(6, 182, 212, 0.10) 0%, transparent 60%),
        linear-gradient(180deg, #0d1b2e 0%, #0a1628 100%);
    }

    .hero-blob {
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      opacity: 0.25;
    }

    .hero-blob-1 {
      width: 600px; height: 600px;
      background: radial-gradient(circle, #2563eb, transparent);
      top: -200px; left: -150px;
    }

    .hero-blob-2 {
      width: 400px; height: 400px;
      background: radial-gradient(circle, #06b6d4, transparent);
      top: 200px; right: -100px;
    }

    .hero-blob-3 {
      width: 300px; height: 300px;
      background: radial-gradient(circle, #7c3aed, transparent);
      bottom: 100px; left: 30%;
    }

    .hero-content { position: relative; z-index: 1; max-width: 820px; }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(37, 99, 235, 0.15);
      border: 1px solid rgba(37, 99, 235, 0.35);
      color: #93c5fd;
      padding: 6px 16px;
      border-radius: 100px;
      font-size: 13px;
      font-weight: 500;
      margin-bottom: 28px;
      letter-spacing: 0.01em;
    }

    .eyebrow::before {
      content: '';
      width: 6px; height: 6px;
      background: #60a5fa;
      border-radius: 50%;
    }

    h1 {
      font-size: clamp(38px, 5.5vw, 64px);
      font-weight: 800;
      line-height: 1.1;
      letter-spacing: -1.5px;
      margin-bottom: 24px;
      background: linear-gradient(135deg, #fff 0%, #cbd5e1 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-sub {
      font-size: 18px;
      color: #94a3b8;
      max-width: 640px;
      margin: 0 auto 40px;
      line-height: 1.7;
      font-weight: 400;
    }

    .hero-sub strong {
      color: #cbd5e1;
      font-weight: 500;
    }

    .hero-ctas {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 14px;
      margin-bottom: 64px;
    }

    .btn-hero {
      background: var(--blue);
      border: none;
      color: var(--white);
      padding: 15px 36px;
      border-radius: 10px;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
      font-family: 'Inter', sans-serif;
      letter-spacing: -0.2px;
      box-shadow: 0 0 40px rgba(37,99,235,0.4);
    }

    .btn-hero:hover {
      background: #1d4ed8;
      transform: translateY(-1px);
      box-shadow: 0 0 55px rgba(37,99,235,0.55);
    }

    .hero-secondary {
      font-size: 13px;
      color: var(--gray-400);
      font-weight: 400;
    }

    /* Logo Row */
    .logo-row {
      position: relative; z-index: 1;
      width: 100%;
      max-width: 900px;
    }

    .logo-row-label {
      font-size: 12px;
      color: var(--gray-500);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 20px;
      font-weight: 500;
    }

    .logo-track {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: center;
      gap: 8px 20px;
    }

    .logo-pill {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 8px;
      padding: 8px 16px;
      font-size: 13px;
      font-weight: 600;
      color: var(--gray-400);
      letter-spacing: 0.02em;
      white-space: nowrap;
    }

    .logo-pill.more {
      color: var(--gray-500);
      font-weight: 400;
    }

    /* Hero product screenshot */
    .hero-screenshot {
      position: relative; z-index: 1;
      margin-top: 72px;
      width: 100%;
      max-width: 1000px;
    }

    .screenshot-frame {
      background: var(--navy-light);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 40px 100px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.05);
    }

    .screenshot-bar {
      background: rgba(255,255,255,0.04);
      border-bottom: 1px solid rgba(255,255,255,0.07);
      padding: 12px 16px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .dot { width: 10px; height: 10px; border-radius: 50%; }
    .dot-red { background: #ff5f57; }
    .dot-yellow { background: #febc2e; }
    .dot-green { background: #28c840; }

    .screenshot-body {
      padding: 0;
      background: linear-gradient(180deg, #112240 0%, #0d1b2e 100%);
      min-height: 380px;
      display: flex;
    }

    .screenshot-sidebar {
      width: 220px;
      border-right: 1px solid rgba(255,255,255,0.06);
      padding: 20px 16px;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .ss-section-label {
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--gray-500);
      font-weight: 600;
      margin: 12px 0 6px;
    }

    .ss-item {
      padding: 7px 10px;
      border-radius: 6px;
      font-size: 12px;
      color: var(--gray-400);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .ss-item.active {
      background: rgba(37,99,235,0.15);
      color: #93c5fd;
    }

    .ss-icon {
      width: 16px; height: 16px;
      background: rgba(255,255,255,0.06);
      border-radius: 4px;
      display: flex; align-items: center; justify-content: center;
      font-size: 9px;
    }

    .screenshot-main {
      flex: 1;
      padding: 24px 28px;
    }

    .ss-header {
      font-size: 15px;
      font-weight: 600;
      color: #e2e8f0;
      margin-bottom: 6px;
    }

    .ss-sub {
      font-size: 12px;
      color: var(--gray-500);
      margin-bottom: 20px;
    }

    .ss-sources-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 10px;
      margin-bottom: 20px;
    }

    .ss-source {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 8px;
      padding: 10px;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 6px;
    }

    .ss-source-icon {
      width: 28px; height: 28px;
      border-radius: 6px;
      display: flex; align-items: center; justify-content: center;
      font-size: 14px;
    }

    .ss-source-name {
      font-size: 11px;
      font-weight: 600;
      color: #cbd5e1;
    }

    .ss-source-count {
      font-size: 10px;
      color: var(--gray-500);
    }

    .ss-status-row {
      display: flex;
      align-items: center;
      gap: 8px;
      background: rgba(16, 185, 129, 0.08);
      border: 1px solid rgba(16, 185, 129, 0.2);
      border-radius: 8px;
      padding: 10px 14px;
      font-size: 12px;
      color: #6ee7b7;
    }

    .ss-dot-green {
      width: 6px; height: 6px;
      background: var(--green);
      border-radius: 50%;
      flex-shrink: 0;
    }

    /* ─── SECTION BASE ─── */
    section { position: relative; }

    .section-inner {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 24px;
    }

    /* ─── PROBLEM SECTION ─── */
    .problem {
      padding: 100px 0;
      background: linear-gradient(180deg, #0a1628 0%, #0d1b2e 100%);
    }

    .section-tag {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      color: var(--cyan);
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 16px;
    }

    h2 {
      font-size: clamp(28px, 3.5vw, 42px);
      font-weight: 800;
      letter-spacing: -1px;
      line-height: 1.15;
      margin-bottom: 20px;
    }

    .problem-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      align-items: start;
      margin-top: 60px;
    }

    .problem-text p {
      font-size: 17px;
      color: var(--gray-400);
      line-height: 1.8;
      margin-bottom: 16px;
    }

    .problem-text p strong {
      color: #e2e8f0;
      font-weight: 500;
    }

    .problem-quote {
      margin-top: 32px;
      background: rgba(255,255,255,0.03);
      border-left: 3px solid var(--cyan);
      border-radius: 0 10px 10px 0;
      padding: 20px 24px;
    }

    .problem-quote blockquote {
      font-size: 15px;
      font-style: italic;
      color: #cbd5e1;
      line-height: 1.7;
      margin-bottom: 12px;
    }

    .problem-quote cite {
      font-size: 12px;
      color: var(--gray-500);
      font-style: normal;
      font-weight: 500;
    }

    .problem-visual {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .pain-card {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 12px;
      padding: 18px 20px;
      display: flex;
      gap: 14px;
      align-items: flex-start;
    }

    .pain-icon {
      width: 36px; height: 36px;
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 17px;
      flex-shrink: 0;
    }

    .pain-icon.red { background: rgba(239,68,68,0.12); }
    .pain-icon.orange { background: rgba(249,115,22,0.12); }
    .pain-icon.yellow { background: rgba(234,179,8,0.12); }

    .pain-title {
      font-size: 14px;
      font-weight: 600;
      color: #e2e8f0;
      margin-bottom: 4px;
    }

    .pain-desc {
      font-size: 13px;
      color: var(--gray-500);
      line-height: 1.6;
    }

    /* ─── HOW IT WORKS ─── */
    .how {
      padding: 100px 0;
      background: var(--navy);
    }

    .how-header {
      text-align: center;
      max-width: 600px;
      margin: 0 auto 64px;
    }

    .steps-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2px;
      position: relative;
    }

    .steps-grid::before {
      content: '';
      position: absolute;
      top: 52px;
      left: calc(16.67% + 24px);
      right: calc(16.67% + 24px);
      height: 1px;
      background: linear-gradient(90deg, var(--blue), var(--cyan), var(--blue));
      opacity: 0.3;
    }

    .step-card {
      background: rgba(255,255,255,0.025);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 16px;
      padding: 32px 28px;
      position: relative;
      transition: border-color 0.2s;
    }

    .step-card:hover {
      border-color: rgba(37,99,235,0.3);
    }

    .step-number {
      width: 44px; height: 44px;
      background: linear-gradient(135deg, var(--blue), var(--cyan));
      border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      font-size: 16px;
      font-weight: 800;
      margin-bottom: 20px;
      box-shadow: 0 0 20px rgba(37,99,235,0.3);
    }

    .step-title {
      font-size: 17px;
      font-weight: 700;
      color: #e2e8f0;
      margin-bottom: 10px;
    }

    .step-desc {
      font-size: 14px;
      color: var(--gray-400);
      line-height: 1.7;
    }

    .step-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 16px;
    }

    .step-tag {
      background: rgba(37,99,235,0.1);
      border: 1px solid rgba(37,99,235,0.2);
      color: #93c5fd;
      font-size: 11px;
      font-weight: 500;
      padding: 3px 10px;
      border-radius: 100px;
    }

    /* ─── DIFFERENTIATION ─── */
    .diff {
      padding: 100px 0;
      background: linear-gradient(180deg, #0a1628 0%, #0d1b2e 100%);
    }

    .diff-header {
      max-width: 600px;
      margin-bottom: 48px;
    }

    .diff-table-wrap {
      overflow-x: auto;
    }

    .diff-table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      font-size: 14px;
    }

    .diff-table th {
      padding: 14px 24px;
      text-align: left;
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.07em;
    }

    .diff-table th:first-child {
      color: var(--gray-500);
    }

    .diff-table th:last-child {
      background: rgba(37,99,235,0.12);
      color: #93c5fd;
      border-radius: 12px 12px 0 0;
    }

    .diff-table td {
      padding: 14px 24px;
      vertical-align: top;
      line-height: 1.5;
    }

    .diff-table tr:not(:last-child) td {
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }

    .diff-table td:first-child {
      color: var(--gray-500);
      border-right: 1px solid rgba(255,255,255,0.05);
    }

    .diff-table td:last-child {
      background: rgba(37,99,235,0.06);
      color: #e2e8f0;
      font-weight: 500;
    }

    .diff-table tr:last-child td:last-child {
      border-radius: 0 0 12px 12px;
    }

    .diff-check {
      color: var(--green);
      font-weight: 700;
      margin-right: 6px;
    }

    .diff-x {
      color: var(--gray-600);
      margin-right: 6px;
    }

    /* ─── RESULTS ─── */
    .results {
      padding: 100px 0;
      background: var(--navy);
    }

    .results-header {
      text-align: center;
      max-width: 560px;
      margin: 0 auto 64px;
    }

    .results-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }

    .result-card {
      background: rgba(255,255,255,0.025);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 16px;
      padding: 32px 32px;
      transition: all 0.2s;
    }

    .result-card:hover {
      border-color: rgba(37,99,235,0.25);
      transform: translateY(-2px);
    }

    .result-stat {
      font-size: 52px;
      font-weight: 800;
      letter-spacing: -2px;
      line-height: 1;
      margin-bottom: 8px;
      background: linear-gradient(135deg, #fff, #93c5fd);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .result-label {
      font-size: 14px;
      color: var(--gray-400);
      margin-bottom: 4px;
    }

    .result-company {
      font-size: 12px;
      color: var(--gray-500);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 20px;
    }

    .result-quote {
      font-size: 13px;
      font-style: italic;
      color: #94a3b8;
      line-height: 1.7;
      border-top: 1px solid rgba(255,255,255,0.06);
      padding-top: 16px;
      margin-top: 4px;
    }

    .result-cite {
      display: block;
      margin-top: 10px;
      font-style: normal;
      font-weight: 600;
      font-size: 12px;
      color: var(--gray-500);
    }

    /* ─── USE CASES ─── */
    .usecases {
      padding: 100px 0;
      background: linear-gradient(180deg, #0a1628 0%, #0d1b2e 100%);
    }

    .usecases-header {
      text-align: center;
      max-width: 560px;
      margin: 0 auto 60px;
    }

    .uc-tabs {
      display: flex;
      gap: 8px;
      justify-content: center;
      margin-bottom: 40px;
    }

    .uc-tab {
      padding: 10px 22px;
      border-radius: 100px;
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      border: 1px solid rgba(255,255,255,0.08);
      color: var(--gray-400);
      background: transparent;
      transition: all 0.2s;
      font-family: 'Inter', sans-serif;
    }

    .uc-tab.active {
      background: rgba(37,99,235,0.15);
      border-color: rgba(37,99,235,0.35);
      color: #93c5fd;
    }

    .uc-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      margin-bottom: 20px;
    }

    /* Internal copilot feature band */
    .copilot-band {
      background: linear-gradient(135deg, rgba(37,99,235,0.1) 0%, rgba(6,182,212,0.07) 100%);
      border: 1px solid rgba(37,99,235,0.25);
      border-radius: 20px;
      padding: 36px 40px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 48px;
      align-items: center;
      margin-top: 4px;
    }

    .copilot-left {}

    .copilot-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(6,182,212,0.1);
      border: 1px solid rgba(6,182,212,0.25);
      color: #67e8f9;
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      padding: 4px 12px;
      border-radius: 100px;
      margin-bottom: 14px;
    }

    .copilot-title {
      font-size: 22px;
      font-weight: 800;
      color: #e2e8f0;
      letter-spacing: -0.5px;
      margin-bottom: 12px;
      line-height: 1.2;
    }

    .copilot-desc {
      font-size: 14px;
      color: var(--gray-400);
      line-height: 1.75;
      margin-bottom: 24px;
    }

    .copilot-features {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .copilot-feature {
      display: flex;
      align-items: flex-start;
      gap: 12px;
    }

    .copilot-feature-icon {
      width: 32px; height: 32px;
      border-radius: 8px;
